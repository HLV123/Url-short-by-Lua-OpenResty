---

<footer class="bg-bg-dark py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
          </svg>
        </div>
        <span class="text-white font-bold text-lg">
          URL Tracker <span class="text-primary">Pro</span>
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm">
        <a href="#features" class="text-gray-400 hover:text-white transition-colors">Tính năng</a>
        <a href="/dashboard/demo" class="text-gray-400 hover:text-white transition-colors">Dashboard</a>
        <a href="https://github.com" target="_blank" class="text-gray-400 hover:text-white transition-colors">GitHub ↗</a>
      </div>

      <!-- Credits -->
      <div class="text-gray-500 text-sm text-center md:text-right">
        Made with ❤️ using <span class="text-gray-400">OpenResty</span> + <span class="text-gray-400">Astro</span>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-800 text-center">
      <p class="text-gray-600 text-xs">
        Zero cloud cost · No registration · Open Source · Portable
      </p>
    </div>
  </div>
</footer>
