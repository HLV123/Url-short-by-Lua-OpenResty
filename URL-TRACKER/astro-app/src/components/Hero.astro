---
---

<section class="hero-gradient relative overflow-hidden pt-24 pb-20 lg:pt-32 lg:pb-28">
  <!-- Background pattern (SVG-based network nodes instead of image) -->
  <div class="absolute inset-0 opacity-[0.12]" style="background-image: url('data:image/svg+xml,%3Csvg%20width%3D%22800%22%20height%3D%22600%22%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%3E%3Cdefs%3E%3CradialGradient%20id%3D%22g1%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%233B82F6%22%20stop-opacity%3D%220.8%22/%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%233B82F6%22%20stop-opacity%3D%220%22/%3E%3C/radialGradient%3E%3CradialGradient%20id%3D%22g2%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%23EE6123%22%20stop-opacity%3D%220.9%22/%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%23EE6123%22%20stop-opacity%3D%220%22/%3E%3C/radialGradient%3E%3C/defs%3E%3Ccircle%20cx%3D%22150%22%20cy%3D%22120%22%20r%3D%2260%22%20fill%3D%22url(%23g1)%22/%3E%3Ccircle%20cx%3D%22650%22%20cy%3D%22200%22%20r%3D%2280%22%20fill%3D%22url(%23g1)%22/%3E%3Ccircle%20cx%3D%22400%22%20cy%3D%22400%22%20r%3D%2250%22%20fill%3D%22url(%23g2)%22/%3E%3Ccircle%20cx%3D%22100%22%20cy%3D%22450%22%20r%3D%2240%22%20fill%3D%22url(%23g1)%22/%3E%3Ccircle%20cx%3D%22700%22%20cy%3D%2280%22%20r%3D%2245%22%20fill%3D%22url(%23g2)%22/%3E%3Cline%20x1%3D%22150%22%20y1%3D%22120%22%20x2%3D%22400%22%20y2%3D%22400%22%20stroke%3D%22%233B82F6%22%20stroke-opacity%3D%220.2%22%20stroke-width%3D%221%22/%3E%3Cline%20x1%3D%22650%22%20y1%3D%22200%22%20x2%3D%22400%22%20y2%3D%22400%22%20stroke%3D%22%233B82F6%22%20stroke-opacity%3D%220.15%22%20stroke-width%3D%221%22/%3E%3Cline%20x1%3D%22150%22%20y1%3D%22120%22%20x2%3D%22650%22%20y2%3D%22200%22%20stroke%3D%22%23818CF8%22%20stroke-opacity%3D%220.12%22%20stroke-width%3D%221%22/%3E%3Cline%20x1%3D%22100%22%20y1%3D%22450%22%20x2%3D%22400%22%20y2%3D%22400%22%20stroke%3D%22%233B82F6%22%20stroke-opacity%3D%220.15%22%20stroke-width%3D%221%22/%3E%3Cline%20x1%3D%22700%22%20y1%3D%2280%22%20x2%3D%22650%22%20y2%3D%22200%22%20stroke%3D%22%23EE6123%22%20stroke-opacity%3D%220.2%22%20stroke-width%3D%221%22/%3E%3C/svg%3E'); background-size: cover; mix-blend-mode: overlay;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Content -->
      <div class="text-center lg:text-left">
        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-white leading-[1.1] mb-6 animate-fade-in">
          Rút gọn URL.<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-yellow-300">Theo dõi mọi click.</span>
        </h1>
        <p class="text-lg text-blue-200/80 mb-10 max-w-lg mx-auto lg:mx-0 animate-fade-in stagger-1">
          Miễn phí. Cực nhanh. Không cần đăng ký.
          <br class="hidden sm:block" />
          Analytics dashboard real-time được xây dựng cho developer.
        </p>

        <!-- Shorten Form -->
        <div id="shorten-form-wrapper" class="animate-slide-up stagger-2">
          <div class="bg-white rounded-xl p-4 sm:p-6 shadow-2xl shadow-black/20 max-w-xl mx-auto lg:mx-0">
            <form id="shorten-form" class="space-y-3">
              <div class="flex flex-col sm:flex-row gap-3">
                <input
                  type="url"
                  id="url-input"
                  class="url-input flex-1"
                  placeholder="Dán URL dài của bạn vào đây..."
                  required
                />
                <button type="submit" class="btn-primary whitespace-nowrap flex items-center justify-center gap-2">
                  <span>Rút gọn ngay</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </button>
              </div>

              <!-- Alias toggle -->
              <div>
                <button type="button" id="alias-toggle" class="text-sm text-blue font-medium hover:underline flex items-center gap-1">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                  Tùy chỉnh alias
                </button>
                <div id="alias-wrapper" class="hidden mt-2">
                  <input
                    type="text"
                    id="alias-input"
                    class="url-input text-sm"
                    placeholder="my-custom-link (3-20 ký tự, a-z, 0-9, -, _)"
                    pattern="[a-zA-Z0-9_-]{3,20}"
                  />
                </div>
              </div>
            </form>

            <!-- Result Card -->
            <div id="result-card" class="hidden mt-4 p-4 bg-emerald-50 border border-emerald-200 rounded-lg animate-slide-in">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-5 h-5 bg-success rounded-full flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-sm font-semibold text-emerald-800">Đã tạo thành công!</span>
              </div>
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
                <code id="result-url" class="text-base font-mono font-medium text-navy break-all"></code>
                <div class="flex gap-2">
                  <button id="copy-btn" class="btn-secondary text-sm !py-2 !px-4 flex items-center gap-1.5" title="Copy link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    Copy
                  </button>
                  <a id="stats-btn" href="#" class="btn-primary text-sm !py-2 !px-4 flex items-center gap-1.5 no-underline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
                    Stats
                  </a>
                </div>
              </div>
            </div>

            <!-- Error -->
            <div id="error-card" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-lg animate-slide-in">
              <p id="error-msg" class="text-sm text-red-700 font-medium"></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Hero Illustration (SVG-based dashboard mockup) -->
      <div class="hidden lg:block animate-fade-in stagger-3">
        <div class="relative">
          <!-- Floating badges -->
          <div class="absolute -top-4 -left-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-lg px-3 py-2 text-white text-xs font-medium shadow-lg animate-bounce" style="animation-duration: 3s;">
            ↑ 2,400 clicks
          </div>
          <div class="absolute top-12 -right-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-lg px-3 py-2 text-xs font-medium shadow-lg" style="animation-duration: 4s; animation-delay: 1s;">
            <span class="text-red-400">●</span> <span class="text-white">Live</span>
          </div>
          <div class="absolute -bottom-2 left-8 bg-white/10 backdrop-blur-md border border-white/20 rounded-lg px-3 py-2 text-white text-xs font-medium shadow-lg" style="animation-duration: 3.5s; animation-delay: 0.5s;">
            🌏 VN · JP · US
          </div>

          <!-- Mock Dashboard -->
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 shadow-2xl">
            <!-- Mini bar chart -->
            <div class="flex items-end gap-1.5 h-32 mb-4">
              {[40, 65, 30, 80, 55, 95, 70, 45, 85, 60, 75, 50, 90, 35, 65, 80, 55, 70, 45, 88, 60, 75, 40, 55].map((h, i) => (
                <div
                  class="flex-1 rounded-t transition-all"
                  style={`height: ${h}%; background: ${i === 5 || i === 12 || i === 19 ? '#EE6123' : 'linear-gradient(to top, #2563EB, #60A5FA)'};`}
                />
              ))}
            </div>
            <!-- Stat pills -->
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-white/10 rounded-lg p-3 text-center">
                <div class="text-2xl font-extrabold text-primary">1,240</div>
                <div class="text-[11px] text-blue-200/70">Total Clicks</div>
              </div>
              <div class="bg-white/10 rounded-lg p-3 text-center">
                <div class="text-2xl font-extrabold text-white">89</div>
                <div class="text-[11px] text-blue-200/70">Unique IPs</div>
              </div>
              <div class="bg-white/10 rounded-lg p-3 text-center">
                <div class="text-2xl font-extrabold text-emerald-400">12</div>
                <div class="text-[11px] text-blue-200/70">Countries</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Alias toggle
  document.getElementById('alias-toggle')?.addEventListener('click', () => {
    const wrapper = document.getElementById('alias-wrapper');
    wrapper?.classList.toggle('hidden');
  });

  // Shorten form submission
  document.getElementById('shorten-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const urlInput = document.getElementById('url-input') as HTMLInputElement;
    const aliasInput = document.getElementById('alias-input') as HTMLInputElement;
    const resultCard = document.getElementById('result-card');
    const errorCard = document.getElementById('error-card');
    const resultUrl = document.getElementById('result-url');
    const statsBtn = document.getElementById('stats-btn') as HTMLAnchorElement;

    resultCard?.classList.add('hidden');
    errorCard?.classList.add('hidden');

    const body: any = { url: urlInput.value };
    if (aliasInput?.value) body.alias = aliasInput.value;

    try {
      const res = await fetch('/api/shorten', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Có lỗi xảy ra');
      }

      if (resultUrl) resultUrl.textContent = data.short_url || `${window.location.origin}/${data.code}`;
      if (statsBtn) statsBtn.href = `/dashboard/${data.code}`;
      resultCard?.classList.remove('hidden');
      urlInput.value = '';
      if (aliasInput) aliasInput.value = '';
    } catch (err: any) {
      const errorMsg = document.getElementById('error-msg');
      if (errorMsg) errorMsg.textContent = err.message;
      errorCard?.classList.remove('hidden');
    }
  });

  // Copy button
  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const url = document.getElementById('result-url')?.textContent;
    if (url) {
      navigator.clipboard.writeText(url).then(() => {
        const btn = document.getElementById('copy-btn');
        if (btn) {
          btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Đã copy!`;
          btn.classList.add('!text-success', '!border-success');
          setTimeout(() => {
            btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy`;
            btn.classList.remove('!text-success', '!border-success');
          }, 2000);
        }
      });
    }
  });
</script>
