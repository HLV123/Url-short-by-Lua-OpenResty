---
---

<div class="bg-white rounded-xl p-6 border border-border stat-card">
  <h3 class="text-lg font-semibold text-navy flex items-center gap-2 mb-4">
    <span>🔗</span> Top nguồn traffic
  </h3>

  <div id="referer-table" class="space-y-2.5">
    <div class="text-sm text-text-muted text-center py-4">Đang tải...</div>
  </div>
</div>

<script>
  function renderRefererTable(referers: { referer: string; clicks: number }[], total: number) {
    const container = document.getElementById('referer-table');
    if (!container) return;

    if (!referers || !referers.length) {
      container.innerHTML = '<div class="text-sm text-text-muted text-center py-4">Chưa có dữ liệu</div>';
      return;
    }

    container.innerHTML = referers.slice(0, 5).map((r) => {
      const pct = total > 0 ? Math.round((r.clicks / total) * 100) : 0;
      const domain = r.referer === 'direct' ? '(Trực tiếp)' : r.referer;
      const icon = r.referer === 'direct' ? '🔗' : '🌐';

      return `
        <div class="flex items-center gap-3 py-1.5">
          <span class="text-sm w-5 text-center">${icon}</span>
          <span class="text-sm text-text-main flex-1 truncate">${domain}</span>
          <span class="text-sm font-semibold text-text-main tabular-nums">${r.clicks.toLocaleString()}</span>
          <span class="text-xs text-text-muted w-10 text-right tabular-nums">${pct}%</span>
        </div>
      `;
    }).join('');
  }

  // @ts-ignore
  window.renderRefererTable = renderRefererTable;
</script>
