---
interface Props {
  code: string;
}
const { code } = Astro.props;
---

<section class="hero-gradient pt-24 pb-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Link info -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 mb-8">
      <div class="flex items-center gap-3">
        <a href="/" class="text-white/60 hover:text-white transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        </a>
        <code class="text-2xl sm:text-3xl font-bold text-white font-mono" id="stats-code">{code}</code>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-white/40">→</span>
        <span class="text-blue-300/80 text-sm truncate max-w-md" id="stats-url">Loading...</span>
      </div>
      <div class="sm:ml-auto flex gap-2">
        <button id="copy-short-url" class="text-white/70 hover:text-white bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded-lg text-xs font-medium transition-all flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copy
        </button>
        <a id="visit-url" href="#" target="_blank" class="text-white/70 hover:text-white bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded-lg text-xs font-medium transition-all flex items-center gap-1.5 no-underline">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Mở link
        </a>
      </div>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" id="stats-cards">
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
        <div class="text-3xl sm:text-[2.5rem] font-extrabold text-white leading-none" id="stat-clicks">—</div>
        <div class="text-sm text-blue-200/70 mt-2">Total Clicks</div>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
        <div class="text-3xl sm:text-[2.5rem] font-extrabold text-white leading-none" id="stat-unique">—</div>
        <div class="text-sm text-blue-200/70 mt-2">Unique IPs</div>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
        <div class="text-3xl sm:text-[2.5rem] font-extrabold text-white leading-none" id="stat-countries">—</div>
        <div class="text-sm text-blue-200/70 mt-2">Countries</div>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
        <div class="text-3xl sm:text-[2.5rem] font-extrabold text-white leading-none" id="stat-created">—</div>
        <div class="text-sm text-blue-200/70 mt-2">Thời gian</div>
      </div>
    </div>
  </div>
</section>
